@model VgcCollege.Web.Models.AttendanceRecord

@{
    ViewData["Title"] = "Create Attendance";
}

<h2>Create Attendance</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="CourseEnrolmentId" class="form-label"></label>
        <select asp-for="CourseEnrolmentId" class="form-select" asp-items="ViewBag.CourseEnrolmentId"></select>
    </div>

    <div class="mb-3">
        <label asp-for="WeekNumber" class="form-label"></label>
        <input asp-for="WeekNumber" class="form-control" />
        <span asp-validation-for="WeekNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SessionDate" class="form-label"></label>
        <input asp-for="SessionDate" class="form-control" type="date" />
        <span asp-validation-for="SessionDate" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Present" class="form-check-input" />
        <label asp-for="Present" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}